{
  "name": "sleeptimer-pro",
  "version": "1.0.0",
  "description": "SleepTimer Pro - Gestionnaire d'arr\u00eat programm\u00e9",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.sleeptimerpro.app",
    "productName": "SleepTimer Pro",
    "artifactName": "SleepTimer-Pro-${version}.exe",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "EaglesFPV",
        "repo": "Sleep-Timer-Pro"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "artifactName": "SleepTimer-Pro-Setup-${version}.exe",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SleepTimer Pro",
      "runAfterFinish": true,
      "installerLanguages": [
        "fr-FR"
      ],
      "language": "1036"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  }
}